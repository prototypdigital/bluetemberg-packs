{
  "name": "bluetemberg-rules",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "bluetemberg sync --silent || true",
    "validate": "node .github/scripts/validate-packs.cjs",
    "generate:catalog": "node scripts/generate-catalog.js",
    "build:site": "node scripts/build-site.js",
    "build:og": "node scripts/build-og.js",
    "lint:md": "markdownlint-cli2 \"packages/**/llm/**/*.md\""
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "bluetemberg": "^0.7.0",
    "markdownlint-cli2": "^0.22.1"
  }
}
